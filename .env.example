# XAKCN Trading Bot - Binance Spot Example Configuration

# Binance API credentials
BINANCE_API_KEY=your_api_key
BINANCE_SECRET_KEY=your_secret_key

# Use testnet while validating the bot
BINANCE_TESTNET=true
BINANCE_RECV_WINDOW=10000

# Trading symbol and timeframe
STOCK_CODE=BTC
OPERATION_CODE=BTCUSDT
CANDLE_PERIOD=1h

# Execution cycle
CYCLE_INTERVAL=60
TEST_MODE=true

# Optional fixed quantity reference
TRADED_QUANTITY=0.001
MIN_BALANCE=100.0
ACCOUNT_CURRENCY=USDT

# Strategy
STRATEGY=quant

# Risk limits (can use fractions or percentages)
MAX_RISK_PER_TRADE=0.02
MAX_POSITION_SIZE=0.20
MAX_DAILY_LOSS=0.05
MAX_DRAWDOWN=0.15
MAX_CONSECUTIVE_LOSSES=3

# Stops
STOP_LOSS_PERCENT=3.0
TAKE_PROFIT_PERCENT=6.0
TRAILING_ACTIVATION=1.5
TRAILING_DISTANCE=1.0

# Quant thresholds
QUANT_BUY_THRESHOLD=0.55
QUANT_SELL_THRESHOLD=-0.55
